{
  "name": "unplugin-strip-attrs",
  "version": "0.1.0",
  "description": "Strip test-related attributes like data-testid and data-cy from JSX, Vue, Svelte, and HTML at build time.",
  "keywords": [
    "data-cy",
    "data-testid",
    "esbuild-plugin",
    "jsx",
    "rollup-plugin",
    "rspack-plugin",
    "strip-attrs",
    "svelte",
    "unplugin",
    "vite-plugin",
    "vue",
    "webpack-plugin"
  ],
  "homepage": "https://github.com/ntnyq/unplugin-strip-attrs#readme",
  "bugs": {
    "url": "https://github.com/ntnyq/unplugin-strip-attrs/issues"
  },
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ntnyq/unplugin-strip-attrs.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./esbuild": {
      "types": "./dist/esbuild.d.mts",
      "import": "./dist/esbuild.mjs"
    },
    "./farm": {
      "types": "./dist/farm.d.mts",
      "import": "./dist/farm.mjs"
    },
    "./rolldown": {
      "types": "./dist/rolldown.d.mts",
      "import": "./dist/rolldown.mjs"
    },
    "./rollup": {
      "types": "./dist/rollup.d.mts",
      "import": "./dist/rollup.mjs"
    },
    "./rspack": {
      "types": "./dist/rspack.d.mts",
      "import": "./dist/rspack.mjs"
    },
    "./unloader": {
      "types": "./dist/unloader.d.mts",
      "import": "./dist/unloader.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.mts",
      "import": "./dist/webpack.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch src",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-p lint typecheck test",
    "release:version": "bumpp",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@farmfe/core": "^1.7.11",
    "@rspack/cli": "^2.0.8",
    "@types/node": "^26.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260622.1",
    "bumpp": "^11.1.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "rolldown": "^1.1.2",
    "rollup": "^4.62.2",
    "tinyglobby": "^0.2.17",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "unloader": "^0.9.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "webpack": "^5.107.2"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx,vue}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=22.13.0 || >=24"
  },
  "packageManager": "pnpm@11.8.0"
}
